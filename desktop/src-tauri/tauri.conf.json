{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/tooling/cli/schema.json",
  "productName": "客来来",
  "version": "1.0.1",
  "identifier": "com.kellai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "客来来",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../backend/dist/kellai-backend": "backend/kellai-backend"
    },
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: jialong Li (G26WSH472M)"
    },
    "icon": [
      "icons/kellai-32x32.png",
      "icons/kellai-128x128.png",
      "icons/kellai-128x128@2x.png",
      "icons/kellai-icon.icns",
      "icons/kellai-icon.ico"
    ]
  }
}
