# ===== 客来来 生产环境配置 =====
# 复制为 .env 后修改对应值：cp .env.example .env

# ----- 必须设置 -----
# JWT 签名密钥（生产环境必须用强随机字符串，否则启动会失败）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(48))"
KELLAI_JWT_SECRET=

# ----- 建议设置 -----
# 密码哈希盐值
KELLAI_PASSWORD_SALT=

# CORS 白名单（逗号分隔，前端域名）
# Vercel 部署后替换为实际域名，如 https://kellai.vercel.app
KELLAI_CORS_ORIGINS=http://localhost:1420,http://localhost:8790

# 后端端口
KELLAI_PORT=8790

# 日志级别
KELLAI_LOG_LEVEL=INFO

# ----- 企业微信服务商第三方应用（企业微信主绑定入口）-----
# 必须是企业微信可访问的公网 HTTPS 后端根地址，不能填写 localhost。
KELLAI_PUBLIC_BASE_URL=
# 服务商后台创建 SaaS 第三方应用后获得。
KELLAI_WECOM_SUITE_ID=
KELLAI_WECOM_SUITE_SECRET=
# 指令回调页面自行设置，必须与服务商后台一致。
KELLAI_WECOM_TOKEN=
KELLAI_WECOM_ENCODING_AES_KEY=
# 未发布测试应用填 1；应用正式发布后改为 0。
KELLAI_WECOM_AUTH_TYPE=0
# 用于加密永久授权码；生产环境应使用独立强随机值并长期保持不变。
KELLAI_WECOM_STORAGE_KEY=
# 远端 SSOT 模式：SuiteSecret/permanent_code 只保存在公网服务端。
# 桌面后端可通过每台设备独立的桥接凭据访问；macOS 生产版优先从钥匙串读取凭据。
KELLAI_WECOM_REMOTE_BASE_URL=
KELLAI_WECOM_REMOTE_BRIDGE_KEY=
# 仅在公网服务端设置，绝不能打进桌面包。
KELLAI_WECOM_BRIDGE_KEY=
# 指令回调：${KELLAI_PUBLIC_BASE_URL}/api/kellai/webhook/wework/suite
# 安装回调：${KELLAI_PUBLIC_BASE_URL}/api/kellai/channels/wework/install/callback

# ----- 抖音开放平台企业号私信渠道 -----
# 移动/网站应用「应用基础信息」中的 Client Key / Client Secret。
KELLAI_DOUYIN_CLIENT_KEY=
KELLAI_DOUYIN_CLIENT_SECRET=
# 小程序 AppID，以及「开发配置 → Webhooks」页面中的 Webhook AppSecret。
# 该 Secret 同时用于 Webhook 验签和生成私信接口所需的 BusinessToken；
# 注意它不是「密钥管理」页面中的普通小程序 AppSecret。
KELLAI_DOUYIN_MINIAPP_APP_ID=
KELLAI_DOUYIN_MINIAPP_SECRET=
# 小程序 c_open_id 与网站应用 open_id 不同命名空间时，用该团队承接 webhook 消息。
# 单团队部署可留空，后端会自动使用唯一已授权的抖音团队。
KELLAI_DOUYIN_DEFAULT_TEAM_ID=
# OAuth 用户令牌加密密钥；生产环境使用独立强随机值并长期保持不变。
KELLAI_DOUYIN_STORAGE_KEY=
# 测试应用需先带 trial.whitelist + user_info 完成基础授权。
# im.direct_message / im.group_fans.create_list 需在开放平台能力通过后再加入；
# 未获权限时提前加入会导致抖音授权页提示「scope违法」。
KELLAI_DOUYIN_SCOPES=trial.whitelist,user_info
# 桌面端使用公网 SSOT 时配置；可与现有企业微信远端桥接共用 base URL，
# 但生产环境推荐使用抖音独立的高熵桥接密钥。
KELLAI_DOUYIN_REMOTE_BASE_URL=
KELLAI_DOUYIN_REMOTE_BRIDGE_KEY=
# 仅在公网服务端配置，绝不能打进桌面包。
KELLAI_DOUYIN_BRIDGE_KEY=
# OAuth 回调：${KELLAI_PUBLIC_BASE_URL}/api/kellai/channels/douyin/oauth/callback
# Webhook 回调：${KELLAI_PUBLIC_BASE_URL}/api/kellai/webhook/douyin
# Webhook 订阅：im_send_msg、im_receive_msg、im_enter_direct_msg、
# im_group_receive_msg、im_group_send_msg、group_fans_event、contract_unauthorize

# ----- 大模型配置（二选一） -----
# 方式 A：在前端「设置 → AI 助手」保存 API Key，后端会写入 data/llm_config.json。
# 方式 B：在这里配置环境变量，后端启动时会自动读取项目根目录、backend、desktop 下的
# .env / .env.local / .env.production。
DEEPSEEK_API_KEY=
# 兼容别名：DEEPSEEK_KEY
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=
# BAILIAN_API_KEY=
# MOONSHOT_API_KEY=
# KIMI_API_KEY=
# SILICONFLOW_API_KEY=
# SILICON_FLOW_API_KEY=
# ARK_API_KEY=
# VOLCENGINE_ARK_API_KEY=
# VOLCENGINE_API_KEY=
# DOUBAO_API_KEY=
# DOUBAO_ARK_API_KEY=
# ZHIPU_API_KEY=
# ZHIPUAI_API_KEY=
# GLM_API_KEY=
# BIGMODEL_API_KEY=
# MINIMAX_API_KEY=
# MIMO_API_KEY=
# XIAOMI_MIMO_API_KEY=
# XAI_API_KEY=
# GROK_API_KEY=

# 常用 Base URL / 模型名覆盖（可选，不填则使用内置默认值）
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6
# VOLCENGINE_ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# VOLCENGINE_ARK_MODEL=doubao-seed-1-6
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=doubao-seed-1-6
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4-flash
# GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-flash
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01
# MIMO_TOKEN_PLAN_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5-pro
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-3-mini

# 自定义 OpenAI-compatible 大模型网关
# KELLAI_LLM_API_KEY=
# KELLAI_LLM_BASE_URL=https://example.com/v1
# KELLAI_LLM_MODEL=your-model-name
# 兼容别名：OPENAI_COMPATIBLE_API_KEY / LLM_API_KEY / AI_API_KEY
# 兼容别名：OPENAI_COMPATIBLE_BASE_URL / OPENAI_COMPATIBLE_API_BASE / LLM_BASE_URL / AI_BASE_URL
# 兼容别名：OPENAI_COMPATIBLE_MODEL / LLM_MODEL / AI_MODEL / MODEL_NAME
# 默认不继承系统 HTTP/SOCKS 代理，避免本机代理依赖缺失导致误判；确需代理时打开。
# KELLAI_LLM_TRUST_ENV_PROXY=1

# 如果已经把 key 写在桌面端 desktop/.env，后端也兼容读取 VITE_ 前缀。
# 注意：生产环境不要把真实 key 打进公开前端包，推荐用设置页保存或服务端 .env。
# VITE_DEEPSEEK_API_KEY=
# VITE_KELLAI_LLM_API_KEY=

# ----- MiMo TTS（教程/朗读默认使用）-----
# 优先使用小米 MiMo V2.5 TTS；未填写时语音功能不可用，不会回退到 macOS 自带 TTS。
# MIMO_API_KEY=
# MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_TTS_MODEL=mimo-v2.5-tts
# MIMO_TTS_VOICE=冰糖
# MIMO_TTS_STYLE=用自然清晰、亲和专业的中文女声播报，适合软件教程讲解。语速适中，吐字清楚。

# ----- Azure Speech TTS（可选备用）-----
# MiMo 未配置时才会尝试 Azure；创建 Azure AI Speech 资源后填写 Key 与 Region，例如 eastasia / southeastasia。
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastasia
# AZURE_SPEECH_VOICE=zh-CN-XiaoxiaoNeural
# 如使用自定义 Speech Endpoint，也可配置：
# AZURE_SPEECH_ENDPOINT=https://eastasia.tts.speech.microsoft.com

# ----- 前端环境变量 -----
# 后端 API 地址（Vercel 部署后替换为实际后端域名）
# 在 Vercel 项目设置 → Environment Variables 中添加
VITE_API_BASE_URL=http://localhost:8790
