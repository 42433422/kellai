# ===== 客来来 生产环境配置 =====
# 复制为 .env 后修改对应值：cp .env.example .env

# ----- 必须设置 -----
# JWT 签名密钥（生产环境必须用强随机字符串，否则启动会失败）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(48))"
KELLAI_JWT_SECRET=

# ----- 建议设置 -----
# 密码哈希盐值
KELLAI_PASSWORD_SALT=

# CORS 白名单（逗号分隔，前端域名）
# Vercel 部署后替换为实际域名，如 https://kellai.vercel.app
KELLAI_CORS_ORIGINS=http://localhost:1420,http://localhost:8790

# 后端端口
KELLAI_PORT=8790

# 日志级别
KELLAI_LOG_LEVEL=INFO

# ----- 前端环境变量 -----
# 后端 API 地址（Vercel 部署后替换为实际后端域名）
# 在 Vercel 项目设置 → Environment Variables 中添加
VITE_API_BASE_URL=http://localhost:8790
